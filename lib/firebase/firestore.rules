rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read and write their own subtree.
    // All sub-collections (profile, savedJobs, appliedJobs, cvs, coverLetters, settings)
    // are covered by the {document=**} wildcard.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
