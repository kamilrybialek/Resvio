# ── AI keys (at least one required) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Job board API keys ───────────────────────────────────────────────────────
# Adzuna: free at https://developer.adzuna.com/ (250 req/day free)
# Covers: SE, NO, DK, GB, DE, NL, FR, PL, ES, IT, AT, BE, CH
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Jooble: email api@jooble.org or register at https://jooble.org/api/about
# Covers: 69 countries including all of Europe
JOOBLE_API_KEY=

# Reed.co.uk: free at https://www.reed.co.uk/developers (UK jobs only)
REED_API_KEY=

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
# After adding the token, run: docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=

# ── Docker Compose profiles ─────────────────────────────────────────────────
# Uncomment to auto-start Cloudflare tunnel:
# COMPOSE_PROFILES=tunnel
