# ── AI keys (at least one required) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → Zero Trust → Networks → Tunnels
# After adding the token, run: docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=

# ── Docker Compose profiles ─────────────────────────────────────────────────
# Uncomment to auto-start Cloudflare tunnel:
# COMPOSE_PROFILES=tunnel
