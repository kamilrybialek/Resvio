# Dependencies — reinstalled inside the image
node_modules

# Next.js build output — rebuilt inside the image
.next

# Version control
.git
.gitignore

# Local AI memory / scratch files (not needed at runtime)
memory/

# CV template images are large and copied via COPY . .
# but we exclude the folder here and re-include only via explicit COPY if
# you ever switch to a multi-stage build.  For now keep them included so
# the single-stage build can serve them.
# CV template/   <-- intentionally NOT ignored; needed at runtime

# Environment files — secrets must be passed via docker-compose or runtime env
.env
.env.local
.env*.local
.env.production
.env.development

# Vercel deployment artifacts
.vercel

# Editor / OS noise
.DS_Store
*.swp
*.swo
.vscode
.idea

# Markdown docs (optional, reduces image size slightly)
README.md
PROJECT_OVERVIEW.md
AGENTS.md
DEPLOY_NAS.md
